# Backend API
UVICORN_IP=0.0.0.0
UVICORN_PORT=8000
FRONTEND_URL=http://localhost:5173

# LLM (Ollama recommended)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# Optional: OpenAI-compatible endpoint (e.g. llama.cpp server)
# LLM_PROVIDER=openai_compatible
# OPENAI_COMPAT_BASE_URL=http://localhost:8080/v1
# OPENAI_COMPAT_API_KEY=local
# OPENAI_COMPAT_MODEL=llama3.2

# RAG
RAG_TOP_K=5
KNOWLEDGE_DIR=backend/knowledge

# Postgres (pgvector)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pgdb
POSTGRES_USER=pguser
POSTGRES_PASSWORD=docker
# Or single URL:
# DATABASE_URL=postgresql://pguser:docker@localhost:5432/pgdb

# Redis and rate limiting (optional)
REDIS_URL=redis://localhost:6379
GLOBAL_RATE_LIMIT=1000/hour
CHAT_RATE_LIMIT=30/minute

# Frontend
VITE_BACKEND_URL=http://localhost:8000
VITE_GITHUB_USERNAME=your_github_username
# VITE_GITHUB_TOKEN=optional_for_higher_rate_limits
