{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",

    // Use bundler-style resolution so TS doesn't require explicit .js extensions
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,

    // Helpful interop defaults
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["api/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules"]
}
