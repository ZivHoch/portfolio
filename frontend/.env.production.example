# Copy to Netlify env vars (or .env.production.local for local prod builds).
# Do NOT include /chat — the app appends that path.
#
# Legacy Gemini API (BackendV2 on Vercel):
# VITE_BACKEND_URL=https://my-portfolio-seven-mauve-33.vercel.app/api
#
# New RAG API (FastAPI on Fly.io):
# VITE_BACKEND_URL=https://your-app.fly.dev

VITE_GITHUB_USERNAME=your_github_username
VITE_BACKEND_URL=https://your-production-api-url
